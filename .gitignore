# =====================================================================
# OS / filesystem noise
# =====================================================================
.DS_Store
**/.DS_Store
Thumbs.db
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# macOS custom folder icons
Icon?
/Icon?

# Vim / Emacs / editor swap files
*.swp
*.swo
*.swn
*~
.*.tmp
*.bak

# =====================================================================
# Repo-local runtime data
# =====================================================================
# Auto-generated by Mp3tag's settings store; do not commit.
Sources/settings.json

# Local TLS certs used by the Mp3tag web server (e.g. localhost).
Sources/localhost*
!Sources/localhost*.example

# User's exported Mp3tag config bundle. Personal — keep out of the repo.
Sources/Mp3tagSettings/

# =====================================================================
# Python
# =====================================================================
# Bytecode and cache directories (applies to Scripts/ and any other
# Python the repo might add later).
**/__pycache__/
**/*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
venv/
env/
.python-version

# =====================================================================
# IDEs and editor config
# =====================================================================
.cursorindexingignore
.idea/
.vscode/
*.iml
*.ipr
*.iws

# Cursor / agent metadata
.kilo/
.cursor/
.aider*
.specstory/

# =====================================================================
# OS / shell detritus
# =====================================================================
# Downloaded archive markers
*.swp
.DS_Store?
.Trashes
.Spotlight-V100
.fseventsd
.AppleDouble
.LSOverride

# Python distribution / packaging
pip-log.txt
pip-delete-this-directory.txt
